{
	"AddNewPetTests": [
		{
			"testCaseId": "NPT_001",
			"scenario": "Add new pet to the store with valid data",
			"module": "pet",
			"method": "POST",
			"endpoints": "/pet",
			"expectedStatusCode": 200,
			"expectedStatusLineMsg": "OK",
			"typeOfTesting": "Positive",
			"loginInputdata": {
				"id": 1,
				"catecory": {
					"id": 1,
					"name": "Dog"
				},
				"name": "Golden Retriever",
				"photoUrls": [
					"https://www.goodhousekeeping.com/life/pets/g4531/cutest-dog-breeds/"
				],
				"tags": [
					{
						"id": 1,
						"name": "puppy"
					}
				],
				"status": "available"
			}
		},
		{
			"testCaseId": "LT_002",
			"scenario": "Check user able to login as admin with invalid credential",
			"module": "Login",
			"method": "POST",
			"endpoints": "/login",
			"expectedStatusCode": 401,
			"expectedStatusLineMsg": "Unauthorized",
			"typeOfTesting": "Positive",
			"loginInputdata": {}
		},
		{
			"testCaseId": "LT_003",
			"scenario": "Check user able to login as admin with valid credential and invalid method",
			"module": "Login",
			"method": "GET",
			"endpoints": "/login",
			"expectedStatusCode": 405,
			"expectedStatusLineMsg": "Method Not Allowed",
			"typeOfTesting": "Positive",
			"loginInputdata": {}
		},
		{
			"testCaseId": "LT_004",
			"scenario": " Check user able to login as admin with valid credential and invalid endpoint",
			"module": "Login",
			"method": "POST",
			"endpoints": "/log",
			"expectedStatusCode": 401,
			"expectedStatusLineMsg": "Unauthorized",
			"typeOfTesting": "Negative",
			"loginInputdata": {}
		},
		{
			"testCaseId": "LT_005",
			"scenario": "Check user able to login as admin with valid credential and invalid content type",
			"module": "Login",
			"method": "POST",
			"endpoints": "/login",
			"expectedStatusCode": 415,
			"expectedStatusLineMsg": "Unsupported Media Type",
			"typeOfTesting": "Negative",
			"loginInputdata": {
				"password": "test",
				"userLoginEmail": "Team601@gmail.com"
			}
		}
	],
